PORT=5000
MONGODB_URI=mongodb://localhost:27017/resume_ai_builder
CLIENT_URL=http://localhost:3000
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Set to true on Railway temporarily to see real API error messages (not for long-term production)
# EXPOSE_API_ERRORS=true

# Optional SMTP (install nodemailer: npm install nodemailer)
# If unset or send fails, OTP is logged to the server console.
# SMTP_HOST=smtp.example.com
# SMTP_EMAIL=your-email@example.com
# SMTP_PASS=your-smtp-password
# SMTP_PORT=587

# OpenRouter (required for /api/ai/tailor-from-job and recruiter screening)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key
# Default model for resume tailor + recruiter scan (use a model your OpenRouter account supports):
OPENROUTER_MODEL=openai/gpt-4o-mini
# Optional override for recruiter screening only:
# RECRUITER_OPENROUTER_MODEL=openai/gpt-4o
# If you see "No endpoints found for anthropic/claude-3.7-sonnet", switch to openai/gpt-4o-mini

# OpenAI Embeddings (optional — local fallback used if unset)
# OPENAI_API_KEY=sk-your-openai-key
# OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# Pinecone Vector DB (optional — MongoDB embeddings used if unset)
# PINECONE_API_KEY=your-pinecone-api-key
# PINECONE_INDEX=recruiter-resumes

# Puppeteer (PDF generation) — only started on save/download PDF API calls
# Local dev: path to Chrome/Chromium (optional if installed in default location)
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Railway: nixpacks.toml installs chromium automatically. Optional override:
# PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
# Alternative if nixpacks.toml is not picked up:
# RAILPACK_DEPLOY_APT_PACKAGES=chromium libnss3 libnspr4 fonts-liberation ca-certificates
