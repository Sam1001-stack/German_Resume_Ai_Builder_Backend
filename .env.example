PORT=5000
MONGODB_URI=mongodb://localhost:27017/resume_ai_builder
CLIENT_URL=http://localhost:3000
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Set to true on Railway temporarily to see real API error messages (not for long-term production)
# EXPOSE_API_ERRORS=true

# Optional SMTP (install nodemailer: npm install nodemailer)
# If unset or send fails, OTP is logged to the server console.
# SMTP_HOST=smtp.example.com
# SMTP_EMAIL=your-email@example.com
# SMTP_PASS=your-smtp-password
# SMTP_PORT=587

# OpenRouter (required for /api/ai/tailor-from-job)
OPENROUTER_API_KEY=sk-or-v1-your-openrouter-api-key
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Puppeteer (PDF generation) — only started on save/download PDF API calls
# Local dev: path to Chrome/Chromium (optional if installed in default location)
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe
